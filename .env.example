# ─── Anthropic (required) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Database (required) ──────────────────────────────────────────────────────
# Supabase pooler connection string (PgBouncer) — for app queries
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection — for Prisma migrations only
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# ─── Upstash Redis (required) ─────────────────────────────────────────────────
# Session cache with 1hr TTL — falls back to Postgres on miss
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─── PDF Export Server (optional) ────────────────────────────────────────────
# Run pdf-server/ on a VPS or locally. Leave blank to disable PDF/PPTX export.
PDF_SERVER_URL=http://localhost:3001
PDF_SERVER_SECRET=your_secret_here

# ─── MCP (optional) ───────────────────────────────────────────────────────────
# Set to activate MCP tool integrations (Google Drive, GitHub, etc.)
MCP_SERVER_URL=

# ─── Logo fetching (optional) ────────────────────────────────────────────────
LOGO_DEV_PUBLISHABLE_KEY=
LOGO_DEV_SECRET_KEY=

# ─── Misc (optional) ──────────────────────────────────────────────────────────
# Extended thinking budget in tokens — 0 disables it
THINKING_BUDGET=0
NEXT_PUBLIC_APP_URL=http://localhost:3000
